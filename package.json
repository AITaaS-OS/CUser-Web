    "prepare": "husky",
    "lint-staged": "lint-staged",
    "eslint": "eslint --ext .js,.jsx,.ts,.tsx",
    "prettier": "prettier --write  \"app/**/*.{js,jsx,ts,tsx,css,less,scss,html,md,json}\""
  },
